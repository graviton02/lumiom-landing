# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this template is safe to commit.

# HubSpot Private App access token (Bearer token for api.hubapi.com).
# Generate from: HubSpot → Settings → Integrations → Private Apps → your app → Auth.
# Region prefix indicates account region: pat-na1-… (US) | pat-na2-… (NA2) | pat-eu1-… (EU).
HUBSPOT_ACCESS_TOKEN=pat-naX-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Client secret — used for OAuth-style flows; optional for Bearer-token CRM calls.
HUBSPOT_CLIENT_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Portal ID (HubSpot Hub ID). Find under HubSpot → Settings → Account Defaults.
# Only required for Forms API; CRM v3 contacts endpoint does not need it.
HUBSPOT_PORTAL_ID=
